APP_NAME=gofiber-hax
APP_ENV=dev

FIBER_ADDR=5001
FIBER_HOST=127.0.0.1
FIBER_ALLOW_ORIGINS=*
FIBER_ALLOW_HEADERS=Origin,Content-Type,Accept,Authorization,X-Request-ID
FIBER_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS

# DB_DRIVER: auto | mongo | mysql | both
DB_DRIVER=mysql

# MONGO
MONGO_URI=
MONGO_USER=admin
MONGO_PASS=
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=example_db

# MYSQL
MYSQL_DSN=root:@tcp(127.0.0.1:3306)/exp_db?parseTime=true
MYSQL_REPLICA_DSN=
MYSQL_AUTO_MIGRATE=false

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty

# Common Log Format:
# ${ip} - - [${time}] "${method} ${url} ${protocol}" ${status} ${bytesSent}
HTTP_ACCESS_LOG_FORMAT=${ip} - - [${time}] "${method} ${url} ${protocol}" ${status} ${bytesSent}
HTTP_ACCESS_LOG_TIME_FORMAT=02/Jan/2006:15:04:05 -0700

# HTTP Hardening
HTTP_ACCESS_LOG_ENABLED=true
HTTP_BODY_LIMIT_MB=4
HTTP_READ_TIMEOUT_SEC=15
HTTP_WRITE_TIMEOUT_SEC=15
HTTP_IDLE_TIMEOUT_SEC=30
HTTP_REQUEST_TIMEOUT_SEC=15
HTTP_RATE_LIMIT_ENABLED=true
HTTP_RATE_LIMIT_MAX=100
HTTP_RATE_LIMIT_WINDOW_SEC=60


# ── Auth Core ─────────────────────────
AUTH_ENABLED=true
AUTH_MODE=jwt         # token | jwt | jwks | google
AUTH_HEADER=Authorization
AUTH_SCHEME=Bearer

# ── Mode: token ───────────────────────
AUTH_TOKEN=secret-key-123

# ── Mode: JWT Self-Issued ─────────────────────────
JWT_ALG=RS256
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_KEY_ID=gofiber-hax-key-1
JWT_JWKS_TTL_SEC=3600
JWT_CLOCK_SKEW_SEC=60
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800
JWT_ISSUER=gofiber-hax
JWT_AUDIENCE=gofiber-hax

# ── Mode: JWKS / External JWT ─────────────────────
JWT_JWKS_URL=https://issuer.example.com/.well-known/jwks.json


# ── Mode: google ──────────────────────
GOOGLE_CLIENT_ID=123456.apps.googleusercontent.com
